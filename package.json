{
  "name": "afrisend",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "test": "jest --watchAll=false --testPathIgnorePatterns=__tests__/integration",
    "test:coverage": "jest --coverage --watchAll=false --testPathIgnorePatterns=__tests__/integration",
    "test:integration": "jest --testPathPattern=__tests__/integration --watchAll=false --testTimeout=30000",
    "test:integration:coverage": "jest --testPathPattern=__tests__/integration --coverage --watchAll=false --testTimeout=30000",
    "test:all": "jest --watchAll=false --testTimeout=30000",
    "server": "ts-node -r tsconfig-paths/register apps/api/src/index.ts",
    "lint": "eslint apps packages --ext .ts,.tsx",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@expo/vector-icons": "^14.0.4",
    "@hookform/resolvers": "^3.9.1",
    "@react-navigation/bottom-tabs": "^6.6.1",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/native-stack": "^6.11.0",
    "@tanstack/react-query": "^5.62.16",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "axios": "^1.7.9",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "expo": "~52.0.0",
    "expo-camera": "~16.0.0",
    "expo-document-picker": "~13.0.0",
    "expo-file-system": "~18.0.0",
    "expo-font": "~13.0.0",
    "expo-image-picker": "~16.0.0",
    "expo-localization": "~16.0.0",
    "expo-network": "~7.0.5",
    "expo-notifications": "^0.29.14",
    "expo-secure-store": "~14.0.0",
    "expo-splash-screen": "~0.29.0",
    "expo-status-bar": "~2.0.1",
    "express": "^5.2.1",
    "i18next": "^23.16.8",
    "ioredis": "^5.10.1",
    "lottie-react-native": "^7.1.0",
    "multer": "^2.1.1",
    "pg": "^8.20.0",
    "react": "^18.3.0",
    "react-hook-form": "^7.54.2",
    "react-i18next": "^15.1.3",
    "react-native": "0.76.3",
    "react-native-gesture-handler": "~2.20.0",
    "react-native-mmkv": "^3.1.0",
    "react-native-phone-number-input": "^2.1.0",
    "react-native-reanimated": "~3.16.1",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.3.0",
    "react-native-svg": "^15.9.0",
    "supertest": "^7.2.2",
    "zod": "^3.23.8",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-hooks": "^8.0.1",
    "@testing-library/react-native": "^12.8.1",
    "@types/react": "~18.3.12",
    "@types/react-native": "~0.73.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "babel-plugin-module-resolver": "^5.0.3",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-native": "^4.1.0",
    "jest": "^29.7.0",
    "jest-expo": "~52.0.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "turbo": "^2.3.3",
    "typescript": "^5.3.3"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFilesAfterEnv": [
      "@testing-library/jest-native/extend-expect",
      "<rootDir>/jest.setup.ts"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg|zustand)"
    ],
    "testMatch": [
      "**/__tests__/**/*.{ts,tsx}",
      "!**/apps/**/__tests__/**",
      "!**/packages/**/__tests__/**"
    ],
    "moduleNameMapper": {
      "^@afrisend/shared(.*)$": "<rootDir>/packages/shared/src$1",
      "^@/server/(.*)$": "<rootDir>/apps/api/src/$1",
      "^@/services/(.*)$": "<rootDir>/apps/api/src/services/$1",
      "^@/(.*)$": "<rootDir>/apps/mobile/src/$1"
    },
    "collectCoverageFrom": [
      "apps/mobile/src/**/*.{ts,tsx}",
      "apps/api/src/**/*.{ts,tsx}",
      "packages/shared/src/**/*.{ts,tsx}",
      "!**/*.d.ts",
      "!**/index.ts",
      "!**/index.tsx",
      "!apps/api/src/services/adapters/**",
      "!apps/mobile/src/navigation/**",
      "!apps/mobile/src/screens/**",
      "!apps/mobile/src/components/kyc/**",
      "!apps/mobile/src/api/client.ts"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 80,
        "statements": 80,
        "functions": 80,
        "branches": 75
      }
    },
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "/__tests__/"
    ]
  }
}
