{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@afrisend/shared": ["packages/shared/src"],
      "@afrisend/shared/*": ["packages/shared/src/*"],
      "@/server/*": ["apps/api/src/*"],
      "@/services/*": ["apps/api/src/services/*"],
      "@/*": ["apps/mobile/src/*"]
    },
    "moduleResolution": "bundler",
    "target": "ES2020",
    "lib": ["ES2020"],
    "allowJs": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "include": ["apps/api", "apps/mobile", "packages", "jest.setup.ts", "__tests__"],
  "exclude": ["apps/web"]
}
