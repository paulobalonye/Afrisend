{
  "expo": {
    "name": "AfriSend",
    "slug": "afrisend",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "afrisend",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A6B3A"
    },
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.afrisend.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "AfriSend uses the camera to capture your ID document and selfie for identity verification.",
        "NSPhotoLibraryUsageDescription": "AfriSend accesses your photo library to upload ID documents and proof of address.",
        "NSFaceIDUsageDescription": "AfriSend uses Face ID to authenticate you securely."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1A6B3A"
      },
      "package": "com.afrisend.app",
      "versionCode": 1,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "USE_BIOMETRIC",
        "USE_FINGERPRINT"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "AfriSend uses the camera to verify your identity."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "AfriSend accesses your photos to upload ID documents."
        }
      ],
      "expo-secure-store",
      "expo-localization",
      "react-native-mmkv"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "YOUR_EAS_PROJECT_ID"
      }
    }
  }
}
