# AfriSend Environment Variables
# Copy to .env and fill in your values

# ===================
# API Configuration
# ===================
EXPO_PUBLIC_API_BASE_URL=https://api.afrisend.com/v1
EXPO_PUBLIC_API_TIMEOUT_MS=30000
EXPO_PUBLIC_ENV=development

# ===================
# YellowCard (Cross-Border Payments)
# ===================
YC_PUBKEY=
YC_SECRET=
YC_BASEURL=https://sandbox.api.yellowcard.io
YC_MERCHANTID=

# ===================
# Veriff (KYC Identity Verification)
# ===================
VERIFF_PKEY=
VERIFF_SKEY=

# ===================
# Resend (Email OTP / Notifications)
# ===================
RESEND_API_KEY=
RESEND_DOMAIN=

# ===================
# Flutterwave (Bank Verification + NGN Payouts)
# ===================
FLW_PUBLIC_KEY=
FLW_SECRET_KEY=
FLW_ENCRYPTION_KEY=

# ===================
# Stripe (Payment Processing)
# ===================
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ===================
# KYC Provider (Mobile)
# ===================
EXPO_PUBLIC_KYC_PROVIDER=veriff
EXPO_PUBLIC_KYC_PARTNER_ID=

# ===================
# Feature Flags
# ===================
EXPO_PUBLIC_ENABLE_BIOMETRICS=true
EXPO_PUBLIC_ENABLE_LIVENESS_CHECK=true
EXPO_PUBLIC_PROGRESSIVE_KYC=true

# ===================
# Local Backend Server
# ===================
PORT=3000
NODE_ENV=development

# PostgreSQL (docker-compose default — change for production)
DATABASE_URL=postgres://afrisend:afrisend_dev_password@localhost:5432/afrisend_dev

# Redis (docker-compose default — change for production)
REDIS_URL=redis://localhost:6379

# For local dev: point mobile app to local backend
# EXPO_PUBLIC_API_BASE_URL=http://localhost:3000/v1
