# Copy to terraform.tfvars and fill in your real values.
# NEVER commit terraform.tfvars — it is in .gitignore

aws_region     = "us-east-1"
aws_account_id = "123456789012"
environment    = "dev"

# Networking — from your existing VPC
vpc_id           = "vpc-xxxxxxxxxxxxxxxxx"
public_subnet_id = "subnet-xxxxxxxxxxxxxxxxx"   # Public subnet for NAT instance
private_rt_id    = "rtb-xxxxxxxxxxxxxxxxx"       # Private route table

# RDS
db_subnet_group_name = "afrisend-dev-subnet-group"
# db_password supplied via env var: export TF_VAR_db_password=<password>

# ECS
ecs_cluster_name = "afrisend-dev"
ecs_service_name = "afrisend-backend"

# Notifications
notification_email = "devops@yourdomain.com"
